{
  "name": "preview-images",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "A desktop application for previewing images with folder navigation",
  "author": {
    "name": "yuchengfan",
    "email": "yuchengfan@users.noreply.github.com"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write src/",
    "version": "npm version patch && git push && git push --tags"
  },
  "build": {
    "appId": "com.preview-images.app",
    "productName": "Preview Images",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Graphics"
    },
    "publish": {
      "provider": "github",
      "owner": "yuchengfan",
      "repo": "preview-images"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.0",
    "tudou-waterfall": "^1.0.0",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0",
    "vue-virtual-scroller": "^2.0.0-beta.8"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.0",
    "eslint": "^10.4.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vue-tsc": "^3.2.8"
  }
}
